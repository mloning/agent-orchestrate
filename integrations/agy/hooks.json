{
  "agent-q-integration": {
    "enabled": true,
    "PreInvocation": [
      {
        "type": "command",
        "command": "/Users/mloning/Documents/Software/agent-orchestrate/integrations/agy/agent-q-invocation.sh"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "run_command|write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mloning/Documents/Software/agent-orchestrate/integrations/agy/agent-q-pre.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mloning/Documents/Software/agent-orchestrate/integrations/agy/agent-q-post.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "/Users/mloning/Documents/Software/agent-orchestrate/integrations/agy/agent-q-stop.sh",
        "timeout": 5
      }
    ]
  }
}
